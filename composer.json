{
    "name": "jeank/jk-boost",
    "description": "JK Boost — AI rules/skills y models reutilizables, centralizados para proyectos Laravel.",
    "type": "library",
    "license": "proprietary",
    "keywords": ["laravel", "ai", "rules", "skills", "ddd"],
    "authors": [
        {
            "name": "Jean Carlo Meléndez"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/prompts": "^0.1.7|^0.2|^0.3"
    },
    "autoload": {
        "psr-4": {
            "JkBoost\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JkBoost\\JkBoostServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
